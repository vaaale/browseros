# BrowserOS environment configuration
#
# The AI provider (Anthropic / OpenAI / OpenAI Codex / local OpenAI-compatible),
# model, base URL, and API key are all configurable at runtime in
# Settings → AI Provider, and persisted to data/provider.json.
# The variables below only seed the initial defaults.

# Seeds the default Anthropic provider key (used until changed in Settings).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Anthropic base URL.
ANTHROPIC_BASE_URL=

# Optional: seed the default model (defaults to claude-sonnet-4-6).
BOS_AGENT_MODEL=claude-opus-4-8

# Optional: comma-separated MCP server endpoints the agent should connect to
# (streamable-http / SSE URLs). Example includes the Claude dev harness.
BOS_MCP_SERVERS=

# Optional: the Claude MCP development harness endpoint used by the dev studio.
BOS_DEV_HARNESS_URL=http://wingman.akhbar.lan:7272/mcp

# NOTE: the harness Agent's subagent_type is generated per BrowserOS sub-agent
# (from its name/id), not configured here.

# Optional: override where user apps are stored. Apps are versioned *content*
# kept in their own standalone git repo (GitFS), independent of the BOS source
# tree. Defaults to <cwd>/apps (gitignored). Point this elsewhere (e.g. an
# external path) if you don't want the app repo nested under the project.
BOS_APPS_DIR=

# Optional: override where runtime state (VFS, settings, memory, …) is stored.
# Defaults to <cwd>/data. The Supervisor sets this per-version for preview
# isolation; you normally don't set it by hand.
BOS_DATA_DIR=

# ── Multi-user Docker deployment (bastion) ──────────────────────────────────
# See docs/dev/deployment.md for the full guide.

# Required: generate with: openssl rand -hex 32
JWT_SECRET=

# "simple" (default, uses bastion/data/users.yml) or "keycloak" (OIDC)
AUTH_PROVIDER=simple

# BOS Docker image tag to use for per-user containers
BOS_IMAGE=browseros:latest

# Git branch/tag to shallow-clone for each new user's BOS source tree
BOS_BASE_REF=main

# Host port for the bastion (default 80)
BASTION_PORT=80

# Public-facing URL for OIDC callbacks
PUBLIC_URL=http://localhost

# Host directory for per-user src/ and data/ bind mounts
VOLUME_BASE=./user-data

# Container idle timeout in ms before auto-stop (default 30 min)
IDLE_TIMEOUT_MS=1800000

# Max simultaneous running BOS containers
MAX_CONCURRENT_INSTANCES=50

# Keycloak OIDC (only when AUTH_PROVIDER=keycloak)
KEYCLOAK_ISSUER=http://keycloak:8080/realms/bos
KEYCLOAK_CLIENT_ID=bos-bastion
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_USERNAME_CLAIM=preferred_username
KEYCLOAK_ADMIN_ROLE=bos-admin
