# BrowserOS environment configuration

# Anthropic API key used by the BOS agent (CopilotKit Anthropic adapter and sub-agents).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the agent model (defaults to claude-sonnet-4-6).
BOS_AGENT_MODEL=claude-sonnet-4-6

# Optional: comma-separated MCP server endpoints the agent should connect to
# (streamable-http / SSE URLs). Example includes the Claude dev harness.
BOS_MCP_SERVERS=

# Optional: the Claude MCP development harness endpoint used by the dev studio.
BOS_DEV_HARNESS_URL=http://wingman.akhbar.home:7272/mcp
